# supplyOS environment variables

# ── Database (shared with systemos) ───────────────────────────────────────────
DATABASE_URL=postgresql://daniel:choose_something_strong@localhost:5433/systemos

# ── AI ────────────────────────────────────────────────────────────────────────
# Option 1: Local Llama via Ollama (run: ollama serve on your Mac, then set URL below)
# If your Mac IP on the local network is e.g. 192.168.1.x:
OLLAMA_URL=http://192.168.1.x:11434
OLLAMA_MODEL=llama3.3

# Option 2: Anthropic API (leave OLLAMA_URL blank to use this instead)
ANTHROPIC_API_KEY=

# ── Search (SearXNG already running on this server) ───────────────────────────
SEARXNG_URL=http://localhost:8080

# ── App ───────────────────────────────────────────────────────────────────────
PORT=4001
LOG_LEVEL=INFO

# ── Research defaults ─────────────────────────────────────────────────────────
# How many search results to fetch per query
SEARCH_RESULTS_PER_QUERY=5
# How many queries to generate per topic
QUERIES_PER_TOPIC=4
# Save markdown reports to this folder (relative to project root)
RESEARCH_OUTPUT_DIR=research
