# fitOS environment variables
# Copy to .env and fill in

# ── Database (shared with systemOS) ─────────────────────────
DATABASE_URL=postgresql://daniel:@localhost:5433/systemos

# ── Garmin ──────────────────────────────────────────────────
GARMIN_EMAIL=
GARMIN_PASSWORD=

# ── Strava ──────────────────────────────────────────────────
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# ── SystemOS ────────────────────────────────────────────────
PYTHONPATH=/home/szmyt/server-services
