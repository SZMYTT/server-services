# nnlos environment variables — copy to .env and fill in

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://daniel:@localhost:5433/systemos

# ── Google Drive ──────────────────────────────────────────────────────────────
# Path to GCP service account JSON with Drive API access
GOOGLE_SERVICE_ACCOUNT_JSON=/home/szmyt/server-services/nnlos/config/service_account.json

# Source folder where MRP Easy CSV exports land (same folder GAS uses)
GOOGLE_DRIVE_SOURCE_FOLDER=1WO_xzMcofIpX-Lc84LLN9ED5TsW4_4bO

# Archive folder IDs per data type (same as GAS config — files moved here after ingest)
DRIVE_ARCHIVE_RAW=1QBGWX1_RE6pRd24KcpCsro9x336iDjhf
DRIVE_ARCHIVE_POST=1RAAyaUz6jWBVE05uxcw7B6nDtRNLNO8r
DRIVE_ARCHIVE_SHOP=1eqJ00JmeJhr3np7C5MxYT71376kyphIr
DRIVE_ARCHIVE_BOMS=1fXR29PZsF9UgpzazWjHRmCEeZOa2SeTp
DRIVE_ARCHIVE_CRITICAL=1BiVikh6ChG6o-x2N-zwcYkO8oSiSYkHw
DRIVE_ARCHIVE_ITEMS=159KnGaZPfMnM2aIFy-m8TUGBGfZwQS0B
DRIVE_ARCHIVE_INV=1TU3ecbfI1n1BSXNEQNKYJ2dmpqaBjffi
DRIVE_ARCHIVE_PO=1yMDsSPP2-pu4lQu2tlvzgX9RphNKmo4u
DRIVE_ARCHIVE_VENDORS=1hQNVO1_2j6oClahN5yDOeEBmn-sKlIJS

# ── Google Sheets write-back ───────────────────────────────────────────────────
# Spreadsheet ID for NNL_INVENTORY (from the URL)
NNL_SPREADSHEET_ID=

# ── Gmail ─────────────────────────────────────────────────────────────────────
GMAIL_CREDENTIALS_JSON=/home/szmyt/server-services/nnlos/config/gmail_credentials.json
GMAIL_TOKEN_JSON=/home/szmyt/server-services/nnlos/config/gmail_token.json

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
PORT=4000
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# ── Sync ──────────────────────────────────────────────────────────────────────
# How often the worker checks Drive for new exports (minutes)
SYNC_INTERVAL_MINUTES=15
