# vendorOS environment variables

# Anthropic Claude API (for supplier intelligence extraction in scrapers)
ANTHROPIC_API_KEY=

# Postgres (shared systemos DB)
DATABASE_URL=postgresql://systemos:password@localhost:5433/systemos

# SearXNG (already running on server)
SEARXNG_URL=http://localhost:8080

# Google (for Gmail draft creation — uses OAuth, not service account)
# Leave blank if not using Gmail draft feature yet
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NNL_INVENTORY Google Sheet ID (for reading data via Sheets API)
NNL_SPREADSHEET_ID=

# Scraper settings
SCRAPER_MAX_RESULTS_PER_QUERY=10
SCRAPER_QUERIES_PER_CATEGORY=5
SCRAPER_OUTPUT_DIR=reports
